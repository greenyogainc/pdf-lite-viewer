<Window x:Class="PdfLiteViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PdfLiteViewer"
        Title="{local:Loc AppTitle}"
        Width="1100" Height="850"
        Background="#FF404040"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BarBg" Color="#FF2B2B2B"/>
        <SolidColorBrush x:Key="BarFg" Color="#FFDDDDDD"/>

        <Style TargetType="Button" x:Key="BarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BarFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton" x:Key="ModeButton">
            <Setter Property="Foreground" Value="{StaticResource BarFg}"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4" Padding="10,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF1F5B94"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border x:Name="ToolbarHost" DockPanel.Dock="Top" Background="{StaticResource BarBg}">
            <DockPanel Margin="8,5" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource BarButton}" Content="{local:Loc Open}" Click="Open_Click" ToolTip="{local:Loc OpenTooltip}"/>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <RadioButton x:Name="ModeFacing" Style="{StaticResource ModeButton}" Content="{local:Loc Facing}" GroupName="mode"
                                 IsChecked="True" Checked="Mode_Checked" ToolTip="{local:Loc FacingTooltip}"/>
                    <RadioButton x:Name="ModeSingle" Style="{StaticResource ModeButton}" Content="{local:Loc Single}" GroupName="mode"
                                 Checked="Mode_Checked" ToolTip="{local:Loc SingleTooltip}"/>
                    <RadioButton x:Name="ModeContinuous" Style="{StaticResource ModeButton}" Content="{local:Loc Scroll}" GroupName="mode"
                                 Checked="Mode_Checked" ToolTip="{local:Loc ScrollTooltip}"/>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <!-- NoMirror: "◀"/"▶" must keep their literal meaning regardless of UI language. -->
                    <StackPanel Orientation="Horizontal" Style="{StaticResource NoMirror}">
                        <Button Style="{StaticResource BarButton}" Content="◀" Click="Prev_Click" ToolTip="{local:Loc PrevPageTooltip}"/>
                        <TextBox x:Name="PageBox" Width="44" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                 Background="#FF1E1E1E" Foreground="{StaticResource BarFg}" BorderBrush="#FF4A4A4A"
                                 KeyDown="PageBox_KeyDown" FontSize="13"/>
                        <TextBlock x:Name="PageCountText" Foreground="{StaticResource BarFg}"
                                   VerticalAlignment="Center" Margin="6,0" FontSize="13"/>
                        <Button Style="{StaticResource BarButton}" Content="▶" Click="Next_Click" ToolTip="{local:Loc NextPageTooltip}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Style="{StaticResource BarButton}" Content="−" Click="ZoomOut_Click" ToolTip="{local:Loc ZoomOutTooltip}"/>
                    <TextBlock x:Name="ZoomText" Text="100%" Foreground="{StaticResource BarFg}"
                               VerticalAlignment="Center" MinWidth="44" TextAlignment="Center" FontSize="13"/>
                    <Button Style="{StaticResource BarButton}" Content="+" Click="ZoomIn_Click" ToolTip="{local:Loc ZoomInTooltip}"/>
                    <Button Style="{StaticResource BarButton}" Content="{local:Loc Fit}" Click="Fit_Click" ToolTip="{local:Loc FitTooltip}"/>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <Button Style="{StaticResource BarButton}" Content="{local:Loc Print}" Click="Print_Click" ToolTip="{local:Loc PrintTooltip}"/>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <Button Style="{StaticResource BarButton}" Content="⛶" Click="Fullscreen_Click" ToolTip="{local:Loc FullscreenTooltip}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <!-- NoMirror: the scroll frame and its rendered pages must never mirror. -->
            <ScrollViewer x:Name="Scroller"
                          Style="{StaticResource NoMirror}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="Scroller_ScrollChanged"
                          PreviewMouseWheel="Scroller_PreviewMouseWheel"
                          Focusable="True"
                          Background="Transparent">
                <ItemsControl x:Name="PagesHost" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Margin="8"
                                    Width="{Binding DisplayWidth}" Height="{Binding DisplayHeight}"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.45"/>
                                </Border.Effect>
                                <Image Source="{Binding Image}" Stretch="Fill"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="EmptyHint"
                       Text="{local:Loc EmptyHint}"
                       Foreground="#FF9A9A9A" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </DockPanel>
</Window>
