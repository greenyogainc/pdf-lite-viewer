<Window x:Class="PdfLiteViewer.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PdfLiteViewer"
        Title="{local:Loc AppTitle}"
        Width="1120" Height="880" MinWidth="1120"
        Background="#FF404040"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BarFg" Color="#FFDDDDDD"/>
        <Style TargetType="Button" x:Key="BarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BarFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF2B2B2B">
            <DockPanel Margin="8,5" LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- NoMirror: same reasoning as MainWindow's nav cluster. -->
                    <StackPanel Orientation="Horizontal" Style="{StaticResource NoMirror}">
                        <Button Style="{StaticResource BarButton}" Content="◀" Click="Prev_Click"/>
                        <TextBlock x:Name="PageLabel" Text="1 / 1" Foreground="{StaticResource BarFg}"
                                   VerticalAlignment="Center" MinWidth="60" TextAlignment="Center" FontSize="13"/>
                        <Button Style="{StaticResource BarButton}" Content="▶" Click="Next_Click"/>
                    </StackPanel>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <TextBlock Text="{local:Loc PagesLabel}" Foreground="{StaticResource BarFg}" VerticalAlignment="Center" Margin="4,0" FontSize="13"/>
                    <!-- MinWidth (not fixed Width) so the combo grows to fit longer translations. -->
                    <ComboBox x:Name="RangeMode" MinWidth="120" VerticalContentAlignment="Center" FontSize="13"
                              SelectionChanged="RangeMode_Changed">
                        <ComboBoxItem Content="{local:Loc RangeAll}" IsSelected="True"/>
                        <ComboBoxItem Content="{local:Loc RangeCurrent}"/>
                        <ComboBoxItem Content="{local:Loc RangeCustom}"/>
                    </ComboBox>
                    <TextBox x:Name="RangeBox" Width="110" Margin="6,0,0,0" VerticalContentAlignment="Center"
                             Background="#FF1E1E1E" Foreground="{StaticResource BarFg}" BorderBrush="#FF4A4A4A"
                             FontSize="13" Visibility="Collapsed" ToolTip="{local:Loc RangeBoxTooltip}"
                             Style="{StaticResource NoMirror}"
                             TextChanged="RangeBox_Changed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="{local:Loc PrinterLabel}" Foreground="{StaticResource BarFg}" VerticalAlignment="Center" Margin="4,0" FontSize="13"/>
                    <ComboBox x:Name="PrinterBox" MinWidth="170" MaxWidth="230" VerticalContentAlignment="Center"
                              FontSize="13" SelectionChanged="Printer_Changed"/>
                    <TextBlock Text="{local:Loc CopiesLabel}" Foreground="{StaticResource BarFg}" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="13"/>
                    <TextBox x:Name="CopiesBox" Width="36" Text="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                             Background="#FF1E1E1E" Foreground="{StaticResource BarFg}" BorderBrush="#FF4A4A4A" FontSize="13"
                             Style="{StaticResource NoMirror}"/>
                    <CheckBox x:Name="BwCheck" Content="{local:Loc BwCheckbox}" Foreground="{StaticResource BarFg}" VerticalAlignment="Center"
                              Margin="10,0,0,0" FontSize="13" Checked="Bw_Toggled" Unchecked="Bw_Toggled"
                              ToolTip="{local:Loc BwCheckboxTooltip}"/>
                    <CheckBox x:Name="DraftCheck" Content="{local:Loc DraftCheckbox}" Foreground="{StaticResource BarFg}" VerticalAlignment="Center"
                              Margin="8,0,0,0" FontSize="13"
                              ToolTip="{local:Loc DraftCheckboxTooltip}"/>
                    <Rectangle Width="1" Fill="#FF4A4A4A" Margin="6,2"/>
                    <Button x:Name="PrintBtn" Style="{StaticResource BarButton}" Content="{local:Loc PrintBtn}" FontWeight="SemiBold" Click="Print_Click"/>
                    <Button Style="{StaticResource BarButton}" Content="{local:Loc CancelBtn}" Click="Cancel_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- NoMirror: the printed page preview must never mirror. -->
        <Grid Margin="20" Style="{StaticResource NoMirror}">
            <Viewbox>
                <Border x:Name="Paper" Background="White" SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <Canvas x:Name="PaperCanvas">
                        <Image x:Name="PageImage" Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Canvas>
                </Border>
            </Viewbox>
            <TextBlock x:Name="EmptyRangeHint" Text="{local:Loc NoPagesInRangeHint}"
                       Foreground="#FF9A9A9A" FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>
