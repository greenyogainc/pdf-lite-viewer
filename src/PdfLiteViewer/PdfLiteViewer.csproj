<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>PdfLiteViewer</AssemblyName>
    <RootNamespace>PdfLiteViewer</RootNamespace>
    <Version>1.0.2</Version>
    <Authors>Green Yoga Inc</Authors>
    <Company>Green Yoga Inc</Company>
    <Product>PDF Lite Viewer</Product>
    <Description>A free, lightweight PDF viewer for Windows.</Description>
    <Copyright>Copyright © 2026 Green Yoga Inc — released as freeware (MIT License)</Copyright>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <SatelliteResourceLanguages>en;es;fr;de;it;pt;pt-BR;ja;ko;zh-Hans;zh-Hant;ru;uk;ar</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PDFtoImage" Version="5.1.0" />
  </ItemGroup>

</Project>
