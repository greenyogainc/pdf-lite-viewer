<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
         xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
         xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
         IgnorableNamespaces="uap rescap">

  <!-- Identity Name/Publisher are placeholders: Partner Center assigns the real
       values when the app is reserved in the Microsoft Store (see packaging/README). -->
  <Identity Name="GreenYogaInc.PDFLiteViewer"
            Publisher="CN=GreenYogaInc"
            Version="1.0.0.0" />

  <Properties>
    <DisplayName>PDF Lite Viewer</DisplayName>
    <PublisherDisplayName>Green Yoga Inc</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>A free, lightweight PDF viewer for Windows. Facing pages, single page full screen, and continuous scrolling. No bloat.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="PdfLiteViewer" Executable="PdfLiteViewer.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements DisplayName="PDF Lite Viewer"
                          Description="A free, lightweight PDF viewer for Windows."
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\Square150x150Logo.png"
                          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"
                         Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="pdf">
            <uap:DisplayName>PDF Document</uap:DisplayName>
            <uap:SupportedFileTypes>
              <uap:FileType>.pdf</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
